#############################################
# BUCIS–BES EC Simulator (.env)
#
# Подсеть: 10.10.10.0/24
# Broadcast: 10.10.10.255
#
# Этот файл — удобный дефолт для запуска на Linux (ПК1, BUCIS/OpenSIPS).
# Для BES на Windows используйте отдельный файл: .env.bes.windows
#############################################

# Формат логов (если пусто — используется дефолт библиотеки логирования)
# Примеры: json, text
LOG_FORMAT=text

############################
# EC (UDP 8890 + 6710/7777)
############################

# Куда BES шлёт ClientQuery (unicast на BUCIS).
# Замените на реальный IP узла bucис в вашей сети.
# EC_BUCIS_ADDR=10.10.10.132
EC_BUCIS_ADDR=10.10.10.132

# Куда BUCIS шлёт ClientReset/KeepAlive (обычно broadcast).
EC_BES_BROADCAST_ADDR=10.10.10.255
# По умолчанию используем broadcast. Если нужно принудительно слать reset/keepalive
# не в broadcast, а в конкретный BES — раскомментируйте и выставьте IP.
# EC_BES_ADDR=10.10.10.50

EC_LISTEN_PORT_8890=8890
EC_BUCIS_QUERY_PORT_6710=6710
EC_BUCIS_QUERY_PORT_7777=7777
# Куда BES шлёт ec_client_query (UDP на EC_BUCIS_ADDR). Дефолт 6710 фиксированный, не из EC_BUCIS_QUERY_PORT_6710.
# Если меняете только порт прослушивания на BUCIS — задайте EC_BES_QUERY_DST_PORT тем же числом.
# EC_BES_QUERY_DST_PORT=6710

EC_CLIENT_RESET_INTERVAL=5s
EC_KEEPALIVE_INTERVAL=2s
# Таймаут ожидания keepalive (0 => 3 * EC_KEEPALIVE_INTERVAL)
EC_KEEPALIVE_TIMEOUT=0s
EC_CLIENT_ANSWER_TIMEOUT=3s
EC_CLIENT_QUERY_RETRY_INTERVAL=1s
EC_CLIENT_QUERY_MAX_RETRIES=3
EC_CALL_SETUP_TIMEOUT=15s
# Лимит длительности разговора после подтверждения ec_client_conversation (0 = без лимита).
# Если sipId из EC пустой — лимит действует сразу после установления SIP.
EC_CONVERSATION_TIMEOUT=30s

# Ограничение диапазона sipId (decimal integer string).
# 0 => без ограничения (поведение как раньше).
# Пример для 16-битного диапазона: 65535 (будут значения 1..65535).
# EC_SIPID_MODULO=65535
EC_SIPID_MODULO=0

# Опционально: фиксировать MAC на BES (если авто-детект неудобен)
# EC_MAC=AA:BB:CC:DD:EE:FF

############################
# SIP (UDP 5060, OpenSIPS)
############################

# SIP домен/realm. В симуляторе это одновременно:
# - адрес/host OpenSIPS для SIP REGISTER/INVITE (`bes` ходит на `SIP_DOMAIN:SIP_PORT`)
# - значение `opensips_ip`, которое `bucis` кладёт в EC KeepAlive и в `ClientAnswer.NewIP`
#   (если задан флаг `--ec-opensips-ip`, он имеет приоритет над `SIP_DOMAIN`)
#
# В дефолтном стенде OpenSIPS обычно запущен на том же узле, что и `bucis`,
# поэтому здесь часто ставят тот же IP, что и в `EC_BUCIS_ADDR`. Это не требование протокола,
# просто удобная настройка "всё на одной машине".
SIP_DOMAIN=10.10.10.132
SIP_PORT=5060

# Учетки для REGISTER/INVITE. Должны существовать в вашей SIP-конфигурации/OpenSIPS.
SIP_USER_BUCIS=bucis
SIP_PASS_BUCIS=bucis

# Если SIP_USER_BES не задан, будет использовано bes_<sipId>.
SIP_USER_BES=bes
SIP_PASS_BES=bes

############################
# RTP / Audio (G.726)
############################

RTP_PORT_RANGE=5003-5009
RTP_G726_PT=2

# ALSA: "default" — обычное устройство; "null" — отключить ввод/вывод.
# Важно: режим без аудио — dev-дефолт (CI/без звука): RTP принимается/отправляется, но ввод/вывод отключены.
# На Linux это должно быть ALSA устройство (например: default, hw:0,0, plughw:1,0).
# Имена вида "Microphone (...)" / "Микрофон (...)" относятся к Windows DirectShow и работают только в .env.bes.windows.
ALSA_DEVICE=default

# Альтернатива (эквивалентно): отключить ввод/вывод, но оставить RTP
# NO_AUDIO=1
